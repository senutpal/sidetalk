<div class="ui container chat-container">

    <div class="ui stackable grid">
  
      <div class="twelve wide computer sixteen wide tablet sixteen wide mobile column">
  
        <div class="ui segment chat-header">
          <h2 class="ui header">
            <i class="comments icon"></i>
            <div class="content">
              General Chatroom
              <div class="sub header">Welcome to Sidetalk community</div>
            </div>
          </h2>
        </div>
  
        <div id="chat-messages" class="ui segment chat-messages">
  
          <% @messages.each do |message| %>
            <div class="chat-message other">
              <div class="bubble">
                <div class="username"><%= message.user.username %></div>
                <div><%= message.body %></div>
              </div>
            </div>
          <% end %>
  
        </div>
  
        <div class="ui segment chat-input">
          <% if logged_in? %>
            <form id="message-form" class="ui form">
              <div class="ui action input fluid">
                <input type="text" id="message-body" placeholder="Type your message..." autocomplete="off">
                <button type="submit" class="ui primary button">
                  <i class="paper plane icon"></i> Send
                </button>
              </div>
            </form>
          <% else %>
            <p><a href="/login">Login</a> to send messages</p>
          <% end %>
        </div>

        <% if logged_in? %>
        <script>
          document.addEventListener("turbo:load", function() {
            const form = document.getElementById("message-form");
            const input = document.getElementById("message-body");
            if (!form) return;

            form.addEventListener("submit", function(e) {
              e.preventDefault();
              const body = input.value.trim();
              if (!body) return;

              fetch("/messages", {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                  "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
                },
                body: JSON.stringify({ message: { body: body } })
              });
              input.value = "";
            });
          });
        </script>
        <% end %>
  
      </div>
  
      <div class="four wide computer eight wide tablet sixteen wide mobile column">
  
        <div class="ui segment">
          <h3 class="ui header">
            <i class="users icon"></i>
            Online Users (<%= @users.count %>)
          </h3>
  
          <div class="ui divided list">
            <% @users.each do |user| %>
              <div class="item online-user">
                <div class="ui green empty circular label"></div>
                <%= user.username %>
              </div>
            <% end %>
          </div>
        </div>
  
      </div>
  
    </div>
  </div>
